{
  "name": "pk-mcp",
  "version": "1.4.0",
  "private": false,
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "pk-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "release": "npm run build && rm -rf pre-release && mkdir -p pre-release && cp -r dist package.json pre-release/ && cp README.release.md pre-release/README.md && sed -i '' 's/\"private\": true/\"private\": false/' pre-release/package.json && mkdir -p release && rsync -av --delete --exclude='.git' pre-release/ release/"
  },
  "dependencies": {
    "@google/genai": "^1.45.0",
    "@modelcontextprotocol/sdk": "^1.5.0",
    "@mozilla/readability": "^0.6.0",
    "@tailwindcss/cli": "^4.2.1",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/sharp": "^0.31.1",
    "axios": "^1.7.9",
    "cssnano": "^7.1.3",
    "dotenv": "^16.4.7",
    "glob": "^13.0.6",
    "jsdom": "^28.1.0",
    "postcss": "^8.5.8",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.1",
    "turndown": "^7.2.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/jsdom": "^27.0.0",
    "@types/node": "^22.13.1",
    "@types/turndown": "^5.0.6",
    "typescript": "^5.7.3"
  }
}
